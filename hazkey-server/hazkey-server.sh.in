#!/usr/bin/env sh

# Grimodex IME server wrapper script
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
ENV_FILE="$CONFIG_HOME/fcitx5-grimodex/env"
# Load user-defined environment variables.
if [ -f "$ENV_FILE" ]; then
    . "$ENV_FILE"
fi

exec "@CMAKE_INSTALL_FULL_LIBDIR@/fcitx5-grimodex/fcitx5-grimodex-server" "$@"
