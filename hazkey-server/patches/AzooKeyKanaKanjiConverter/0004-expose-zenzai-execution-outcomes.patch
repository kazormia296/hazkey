diff --git a/Sources/KanaKanjiConverterModule/ConverterAPI/KanaKanjiConverter.swift b/Sources/KanaKanjiConverterModule/ConverterAPI/KanaKanjiConverter.swift
--- a/Sources/KanaKanjiConverterModule/ConverterAPI/KanaKanjiConverter.swift
