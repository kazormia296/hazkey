@@ -40,6 +40,51 @@ public struct ZenzaiCandidateEvaluationMetadata: Hashable, Sendable {
     }
 }
 
+public enum ZenzaiEvaluationOutcome: String, Hashable, Sendable {
+    case pass
+    case fixRequired = "fix_required"
+    case wholeResult = "whole_result"
+    case error
+}
+
+public enum ZenzaiEvaluationTerminalOutcome: String, Hashable, Sendable {
+    case pass
+    case fixRequired = "fix_required"
+    case wholeResult = "whole_result"
+    case error
+    case inferenceLimit = "inference_limit"
+    case noCandidate = "no_candidate"
+}
+
+public struct ZenzaiRequestEvaluationMetadata: Hashable, Sendable {
+    public private(set) var attemptCount = 0
+    public private(set) var passCount = 0
+    public private(set) var fixRequiredCount = 0
+    public private(set) var wholeResultCount = 0
+    public private(set) var errorCount = 0
+    public private(set) var terminalOutcome: ZenzaiEvaluationTerminalOutcome?
+
+    public init() {}
+
+    mutating func recordAttempt(_ outcome: ZenzaiEvaluationOutcome) {
+        attemptCount += 1
+        switch outcome {
+        case .pass:
+            passCount += 1
+        case .fixRequired:
+            fixRequiredCount += 1
+        case .wholeResult:
+            wholeResultCount += 1
+        case .error:
+            errorCount += 1
+        }
+    }
+
+    mutating func finish(_ outcome: ZenzaiEvaluationTerminalOutcome) {
+        terminalOutcome = outcome
+    }
+}
+
