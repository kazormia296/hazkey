	sha256sums_x86_64 = RELEASE_X86_64_ARCHIVE_SHA256
	sha256sums_x86_64 = RELEASE_X86_64_SIDECAR_SHA256
	source_aarch64 = fcitx5-grimodex-0.2.1-aarch64.tar.zst::https://github.com/kazormia296/hazkey/releases/download/v0.2.1/fcitx5-grimodex-0.2.1-aarch64.tar.zst
