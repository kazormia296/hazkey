# Maintainer: Grimodex Project <kazormia296@users.noreply.github.com>

pkgname=fcitx5-grimodex-bin
_pkgname=fcitx5-grimodex
pkgver=0.2.1
pkgrel=1
pkgdesc='Project-aware Japanese input method for Grimodex and Fcitx5 (binary release)'
arch=('x86_64' 'aarch64')
url='https://github.com/kazormia296/hazkey'
license=('MIT')
depends=('fcitx5' 'glibc' 'gcc-libs' 'protobuf' 'qt6-base')
optdepends=('grimodex: publish project dictionaries and local conversion conditions')
provides=("fcitx5-grimodex=${pkgver}")
conflicts=('fcitx5-grimodex')
options=('!strip')
install=fcitx5-grimodex.install

source_x86_64=(
  "${_pkgname}-${pkgver}-x86_64.tar.zst::${url}/releases/download/v${pkgver}/${_pkgname}-${pkgver}-x86_64.tar.zst"
  "${_pkgname}-${pkgver}-x86_64.tar.zst.sha256::${url}/releases/download/v${pkgver}/${_pkgname}-${pkgver}-x86_64.tar.zst.sha256"
)
sha256sums_x86_64=('SKIP' 'SKIP')
source_aarch64=(
  "${_pkgname}-${pkgver}-aarch64.tar.zst::${url}/releases/download/v${pkgver}/${_pkgname}-${pkgver}-aarch64.tar.zst"
  "${_pkgname}-${pkgver}-aarch64.tar.zst.sha256::${url}/releases/download/v${pkgver}/${_pkgname}-${pkgver}-aarch64.tar.zst.sha256"
)
sha256sums_aarch64=('SKIP' 'SKIP')

prepare() {
  local archive="${_pkgname}-${pkgver}-${CARCH}.tar.zst"
  local checksum="${archive}.sha256"
  local expected actual

  expected="$(awk 'NR == 1 { print $1 }' "${srcdir}/${checksum}")"
  actual="$(sha256sum "${srcdir}/${archive}" | awk '{ print $1 }')"
  if [[ ! "${expected}" =~ ^[[:xdigit:]]{64}$ || "${actual}" != "${expected}" ]]; then
    printf 'Release checksum validation failed for %s\n' "${archive}" >&2
    return 1
  fi
}

package() {
  local archive="${_pkgname}-${pkgver}-${CARCH}.tar.zst"

  if bsdtar -tf "${srcdir}/${archive}" | grep -Eq '(^/|(^|/)\.\.(/|$))'; then
    printf 'Release archive contains an unsafe path\n' >&2
    return 1
  fi
  bsdtar -xf "${srcdir}/${archive}" -C "${pkgdir}"

  if find "${pkgdir}" -mindepth 1 -maxdepth 1 ! -name usr -print -quit | grep -q .; then
    printf 'Release archive contains files outside usr/\n' >&2
    return 1
  fi

  test -f "${pkgdir}/usr/lib/fcitx5/fcitx5-grimodex.so"
  test -x "${pkgdir}/usr/bin/fcitx5-grimodex-server"
  test -e "${pkgdir}/usr/bin/fcitx5-grimodex-settings"
  test -f "${pkgdir}/usr/share/licenses/fcitx5-grimodex/LICENSE"
  test -f "${pkgdir}/usr/share/licenses/fcitx5-grimodex/NOTICE.md"

  if find "${pkgdir}/usr" -print | grep -Eqi '(^|/)hazkey([^/]*)(/|$)'; then
    printf 'Release archive contains a public Hazkey path\n' >&2
    return 1
  fi
  if grep -aiRlE 'Qt6Network|QNetwork(AccessManager|Request|Reply)|FoundationNetworking|URLSession|NSURLConnection|AsyncHTTPClient|NIOHTTP(Client|1)|curl_(easy|multi|share|url)_|libcurl\.so' \
    "${pkgdir}/usr" >/dev/null; then
    printf 'Release archive contains a forbidden network/download marker\n' >&2
    return 1
  fi
}
